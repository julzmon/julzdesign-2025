        <div class="brand-letter border-l border-gray-300 flex justify-center pt-[7rem] pb-5">z</div>
        <div class="brand-letter border-l border-gray-300 flex justify-center pt-[7rem] pb-5">d</div>
        <div class="brand-letter border-l border-gray-300 flex justify-center pt-[7rem] pb-5">e</div>
        <div class="brand-letter border-l border-gray-300 flex justify-center pt-[7rem] pb-5">s</div>
        <div class="brand-letter border-l border-gray-300 flex justify-center pt-[7rem] pb-5">i</div>
